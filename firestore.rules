rules_version = '2';

// Reglas de seguridad de Firestore para el "Tinder de películas" de Cinexa.
//
// Cómo aplicarlas:
//   Consola Firebase → Firestore Database → pestaña "Reglas" → pega esto →
//   "Publicar". (O con la CLI: `firebase deploy --only firestore:rules`.)
//
// Modelo de seguridad: todo requiere sesión (auth anónima). Una sala se puede
// LEER por cualquier usuario autenticado (necesario para unirse por código),
// pero los swipes/candidatos/matches solo los ven y editan los miembros.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    match /rooms/{roomId} {
      // Leer la sala: cualquiera autenticado (para poder unirse por código).
      allow read: if signedIn();

      // Crear: el creador debe ser el único miembro inicial.
      allow create: if signedIn()
        && request.resource.data.members == [request.auth.uid];

      // Actualizar: o ya eres miembro, o te estás uniendo a una sala con cupo
      // (conservando los miembros existentes y agregándote a ti mismo).
      // El cupo lo define maxMembers del propio documento (2 a 4).
      allow update: if signedIn() && (
        request.auth.uid in resource.data.members
        || (
          resource.data.members.size() < resource.data.maxMembers
          && request.resource.data.members.hasAll(resource.data.members)
          && request.resource.data.members.size() == resource.data.members.size() + 1
          && request.auth.uid in request.resource.data.members
        )
      );

      allow delete: if false;

      // Solo los miembros de la sala acceden a las subcolecciones.
      function isMember() {
        return signedIn()
          && request.auth.uid in
             get(/databases/$(database)/documents/rooms/$(roomId)).data.members;
      }

      match /candidates/{movieId} {
        allow read, write: if isMember();
      }

      match /swipes/{swipeId} {
        allow read, write: if isMember();
      }

      match /matches/{movieId} {
        allow read, write: if isMember();
      }
    }
  }
}
